# Vantare Ingeniero — Environment Configuration

# LLM — StepFun (API compatible OpenAI)
LLM_BASE_URL=https://api.stepfun.ai/step_plan/v1
LLM_MODEL=step-3.5-flash
LLM_API_KEY=

# LMU REST API
LMU_REST_URL=""
POLL_INTERVAL_API=3.0

# Frecuencias del Backend
TELEMETRY_POLL_RATE=0.05
STRATEGY_POLL_RATE=2.0

# Windows native telemetry (no sidecar). 0 = legacy sidecar path
VANTARE_NATIVE_TELEMETRY=1

# Servidor Local
HOST="127.0.0.1"
PORT=8008
TTS_BACKEND=edge

# ElevenLabs TTS (opcional)
# ELEVENLABS_API_KEY=""
# ELEVENLABS_VOICE_ID=""

# ASR Whisper (PTT local) — startup = precarga al arrancar backend
WHISPER_PRELOAD=startup
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8