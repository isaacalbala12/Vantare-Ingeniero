# Vantare Ingeniero — Environment Configuration

# LLM — StepFun (API compatible OpenAI)
LLM_BASE_URL=https://api.stepfun.ai/step_plan/v1
LLM_MODEL=step-3.5-flash
LLM_API_KEY=

# LMU REST API
LMU_REST_URL=""
POLL_INTERVAL_API=3.0

# Frecuencias del Backend
TELEMETRY_POLL_RATE=0.05
STRATEGY_POLL_RATE=2.0

# Windows native telemetry — VANTARE_NATIVE_TELEMETRY env overrides NATIVE_TELEMETRY setting
VANTARE_NATIVE_TELEMETRY=1
NATIVE_TELEMETRY=true

# Servidor Local
HOST="127.0.0.1"
PORT=8008
TTS_BACKEND=edge

# Gemini TTS (opcional — Hub puede elegir proveedor gemini por rol)
# GEMINI_API_KEY=""
# GEMINI_TTS_VOICE=Kore

# ElevenLabs TTS (opcional)
# ELEVENLABS_API_KEY=""
# ELEVENLABS_VOICE_ID=""

# ASR Whisper (PTT local) — off en beta slim; startup = precarga al arrancar
WHISPER_PRELOAD=off
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Beta slim — desactiva RAG/MQTT/commentary batch en arranque
BETA_SLIM=true
ENABLE_CHROMA_RAG=false
ENABLE_MQTT=false
ENABLE_COMMENTARY_BATCH=false