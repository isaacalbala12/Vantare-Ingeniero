{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vantare Ingeniero IA",
  "version": "0.1.0",
  "identifier": "com.vantare.ingeniero",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vantare Ingeniero",
        "width": 480,
        "height": 520,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Capabilities for the main window",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "global-shortcut:default",
            "global-shortcut:allow-register",
            "global-shortcut:allow-unregister",
            "global-shortcut:allow-is-registered"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "binaries/backend": "backend"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
