{
  "name": "frontend",
  "private": true,
  "version": "0.2.3",
  "type": "module",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:1420 && npm run build:electron && electron .\"",
    "build": "tsc && vite build",
    "build:electron": "tsc -p electron/tsconfig.json && node scripts/electron-postbuild.mjs",
    "build:desktop": "npm run build && npm run build:electron && electron-builder --config electron-builder.yml",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "tauri": "tauri",
    "electron": "electron ."
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-global-shortcut": "^2.2.0",
    "@tauri-apps/plugin-opener": "^2.2.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.2.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.1.7",
    "wait-on": "^8.0.2"
  }
}
